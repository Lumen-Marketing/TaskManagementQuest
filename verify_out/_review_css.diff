+/* ---- Task detail as a full page (#taskDetailWrap) ----
+   Clicking a task row relocates #detailPane into this full-page surface instead
+   of a centered modal. The detail lays out as a dashboard of blocks (a meta card
+   on the side, the description / subtasks / activity / comments as cards in the
+   main column) so the content fills the width instead of running far down the
+   page — with the topbar + sidebar still in view. */
+#taskDetailWrap.detail-page {
+  background: var(--bg);
+  padding: 20px 24px 48px;
+}
+/* ID specificity beats the legacy mobile `.detail:not(.hidden)` overlay rules so
+   the surface stays a normal in-flow element at every breakpoint. The outer
+   container is transparent — the blocks inside are the visible cards. */
+#taskDetailWrap .detail,
+#taskDetailWrap .detail:not(.hidden) {
+  position: static;
+  inset: auto;
+  z-index: auto;
+  width: 100%;
+  max-width: 1180px;
+  margin: 0 auto;
+  border: 0;
+  border-radius: 0;
+  background: transparent;
+  box-shadow: none;
+  overflow: visible;
+  animation: fadeIn var(--dur-short) var(--ease-out);
+}
+#taskDetailWrap .detail-head {
+  padding: 0 0 14px;
+  margin-bottom: 18px;
+  border-bottom: 1px solid var(--ink);
+}
+.detail-back {
+  display: inline-flex; align-items: center; gap: 6px;
+  background: none; border: 0; cursor: pointer;
+  color: var(--ink-3); font-size: 12px; font-weight: 600;
+  padding: 2px 4px 2px 0; margin-bottom: 10px;
+  border-radius: var(--radius-sm);
+}
+.detail-back:hover { color: var(--ink); }
+.detail-back i { font-size: 16px; }
+
+/* Block dashboard, organised into three columns:
+     meta (left)  ·  feed: description / activity / comments (centre)  ·  rail:
+     subtasks / time entries (right).
+   Each block is a hard black-outline card (var(--ink) adapts: near-black in the
+   light themes, snow in dark) to match the app's B&W-outline aesthetic. */
+#taskDetailWrap .detail-body.detail-grid {
+  display: grid;
+  grid-template-columns: 300px minmax(0, 1fr) 280px;
+  grid-template-areas: "side main rail";
+  gap: 18px;
+  align-items: start;
+  padding: 0;
+  flex: none;
+}
+.detail-side { grid-area: side; display: flex; flex-direction: column; gap: 14px; position: sticky; top: 18px; }
+.detail-main { grid-area: main; display: flex; flex-direction: column; gap: 18px; min-width: 0; }
+.detail-rail { grid-area: rail; display: flex; flex-direction: column; gap: 14px; position: sticky; top: 18px; }
+
+.detail-card {
+  border: 1px solid var(--ink);
+  border-radius: var(--radius-md);
+  background: var(--surface);
+  box-shadow: none;
+  padding: 14px 16px;
+}
+.detail-card .detail-card-title:first-child { margin-top: 0; }
+.detail-card-title {
+  font-size: 10.5px; text-transform: uppercase; letter-spacing: 0.08em;
+  color: var(--ink-3); font-weight: 700; margin-bottom: 10px;
+  padding-bottom: 8px; border-bottom: 1px solid var(--ink);
+}
+.detail-actions-row { display: flex; gap: 6px; }
+/* Inside the meta card the rows are tighter and divided, not full-width chips. */
+#taskDetailWrap .detail-card .detail-row { padding: 7px 0; border-bottom: 1px solid var(--border); }
+#taskDetailWrap .detail-card .detail-row:last-child { border-bottom: 0; padding-bottom: 0; }
+#taskDetailWrap .detail-row .priority-block { justify-self: start; }
+/* The comments card keeps its own internal spacing. */
+#taskDetailWrap .cm-section { margin-top: 0; }
+/* Edit mode is a single-column form (no .detail-grid) — keep it readable-width
+   and on a black-outline card rather than sprawling across the full page. */
+#taskDetailWrap .detail-body:not(.detail-grid) {
+  max-width: 760px;
+  padding: 18px 20px;
+  border: 1px solid var(--ink);
+  border-radius: var(--radius-md);
+  background: var(--surface);
+  box-shadow: none;
+}
+
+/* Two columns (meta + feed) — the rail tucks under the meta column. */
+@media (max-width: 1180px) {
+  #taskDetailWrap .detail-body.detail-grid {
+    grid-template-columns: 300px minmax(0, 1fr);
+    grid-template-areas:
+      "side main"
+      "rail main";
+  }
+  .detail-rail { position: static; }
+}
+/* Single column on narrow/phone widths. */
+@media (max-width: 820px) {
+  #taskDetailWrap.detail-page { padding: 16px 14px 40px; }
+  #taskDetailWrap .detail-body.detail-grid {
+    grid-template-columns: 1fr;
+    grid-template-areas:
+      "side"
+      "rail"
+      "main";
+  }
+  .detail-side, .detail-rail { position: static; }
+}
